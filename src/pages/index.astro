---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostList from '../components/PostList.astro';
import { getCollection } from 'astro:content';
// Get all blog posts and sort them by date
const allPosts = await getCollection('posts');
const sortedPosts = allPosts.sort((a, b) => {
  return new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf();
});
// Show up to 5 posts on the frontpage
const posts = sortedPosts.slice(0, 5).map(post => ({
  ...post,
  url: `${import.meta.env.BASE_URL}/posts/${post.id}`,
  frontmatter: post.data
}));
---
<BaseLayout title="Welcome">
  <div class="max-w-4xl mx-auto">
    <section class="text-center py-[8vh]" transition:animate="fade">
      <h1 class="text-7xl mb-8 font-bold">sinibaca</h1>
      <p class="text-2xl text-muted-foreground max-w-3xl mx-auto mb-14">
        Nulis kalau semua kondisi mendukung, dan itu jarang terjadi.
      </p>
      <a href="https://www.instagram.com/riskiregitaa/" target="_blank" rel="noopener noreferrer" class="btn-primary btn-lg tracking-wide no-underline hover:no-underline transform transition-all duration-300 hover:scale-105 hover:shadow-[0_3.5rem_5rem_rgba(21,21,21,0.3)] shadow-[0_3rem_4rem_rgba(21,21,21,0.25)] dark:bg-white dark:text-black dark:hover:bg-gray-100">
        Kenalan di Instagram
      </a>
    </section>
    <section class="mx-auto" transition:animate="fade">
      <PostList posts={posts} showImages={false} showExcerpt={false} showSeparators={true} showTags={false}/>
      <div class="text-center mt-24">
        <a href={`${import.meta.env.BASE_URL}/journal`} class="text-lg font-medium text-black dark:text-white py-2 px-4 rounded-md inline-block focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 hover:underline">
          Lihat Semua Tulisan <span aria-hidden="true">→</span>
        </a>
      </div>
    </section>
  </div>
</BaseLayout>
